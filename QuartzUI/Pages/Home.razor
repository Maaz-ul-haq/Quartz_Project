@page "/"

<PageTitle>Quartz Scheduler</PageTitle>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="jumbotron">
                <h1 class="display-4">⏱️ Quartz Scheduler</h1>
                <p class="lead">A complete job scheduling solution using Quartz.NET, Blazor WebAssembly, and ASP.NET Core</p>
                <hr class="my-4">
                <p>Manage and schedule jobs directly from the UI with full CRUD operations and monitoring capabilities.</p>
                <a class="btn btn-primary btn-lg" href="/jobs" role="button">Go to Jobs Manager →</a>
            </div>

            <div class="row mt-5">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">📧 Email Jobs</h5>
                            <p class="card-text">Schedule automated email sending with cron expressions. Perfect for daily reports, notifications, and reminders.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">🔗 HTTP API Jobs</h5>
                            <p class="card-text">Call external APIs on a schedule. Supports custom headers and request bodies for advanced integrations.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-md-12">
                    <h4>Features</h4>
                    <ul class="list-group">
                        <li class="list-group-item">✅ Create, update, and delete jobs</li>
                        <li class="list-group-item">✅ Pause and resume jobs anytime</li>
                        <li class="list-group-item">✅ Track job execution history</li>
                        <li class="list-group-item">✅ Flexible cron scheduling</li>
                        <li class="list-group-item">✅ RESTful API backend</li>
                        <li class="list-group-item">✅ Modern Blazor WebAssembly UI</li>
                    </ul>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-md-12">
                    <h4>Quick Cron Examples</h4>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Expression</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><code>0 0 9 * * ?</code></td>
                                <td>Every day at 9:00 AM</td>
                            </tr>
                            <tr>
                                <td><code>0 */5 * * * ?</code></td>
                                <td>Every 5 minutes</td>
                            </tr>
                            <tr>
                                <td><code>0 0 0 1 * ?</code></td>
                                <td>First day of every month at midnight</td>
                            </tr>
                            <tr>
                                <td><code>0 0 9 * * MON-FRI</code></td>
                                <td>Weekdays at 9:00 AM</td>
                            </tr>
                            <tr>
                                <td><code>0 0 8,12,18 * * ?</code></td>
                                <td>Every day at 8 AM, 12 PM, and 6 PM</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

