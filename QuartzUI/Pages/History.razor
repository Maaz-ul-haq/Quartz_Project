@page "/history"
@inject ApiClient ApiClient
@inject SweetAlertService AlertService
@inject IJSRuntime Js
@using QuartzUI.Services
@using System.Text.Json

<div class="container-fluid mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">API Call History</h2>
            <p class="text-muted small">View all API call histories and their responses</p>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading API call history...</p>
        </div>
    }
    else if (ApiCallHistories == null || ApiCallHistories.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            <strong>No records found</strong> - There are no API call histories to display yet.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Job Name</th>
                        <th>Status Code</th>
                        <th>Success</th>
                        <th>Executed At</th>
                        <th>Response</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var history in ApiCallHistories)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-secondary">@history.Id</span>
                            </td>
                            <td>
                                @if (history.Job != null)
                                {
                                    <strong>@history.Job.JobName</strong>
                                }
                                else
                                {
                                    <span class="text-muted">Unknown</span>
                                }
                            </td>
                            <td>
                                @if (history.StatusCode.HasValue)
                                {
                                    <code>@history.StatusCode</code>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (history.IsSuccess)
                                {
                                    <span class="badge bg-success">Success</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Failed</span>
                                }
                            </td>
                            <td>
                                <small class="text-muted">@history.ExecutedAt.ToString("g")</small>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(history.ResponseBody))
                                {
                                    <button class="btn btn-sm btn-primary" @onclick="() => ShowResponseDetails(history)">
                                        View
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted">Empty</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Response Details Modal -->
@if (SelectedHistory != null)
{
    <div class="modal d-block" style="background-color: rgba(0,0,0,0.5);" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        Response Details - 
                        @if (SelectedHistory.Job != null)
                        {
                            <span>@SelectedHistory.Job.JobName</span>
                        }
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label"><strong>Status Code:</strong></label>
                        <div>@(SelectedHistory.StatusCode?.ToString() ?? "N/A")</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Status:</strong></label>
                        <div>
                            @if (SelectedHistory.IsSuccess)
                            {
                                <span class="badge bg-success">Success</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Failed</span>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(SelectedHistory.ErrorMessage))
                    {
                        <div class="mb-3">
                            <label class="form-label"><strong>Error Message:</strong></label>
                            <div class="alert alert-danger mb-0">
                                @SelectedHistory.ErrorMessage
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label"><strong>Response Body:</strong></label>
                        <pre class="bg-light p-3 rounded" style="max-height: 400px; overflow-y: auto;"><code>@FormattedResponseBody</code></pre>
                    </div>

                    <div class="mb-0">
                        <label class="form-label"><strong>Executed At:</strong></label>
                        <div>@SelectedHistory.ExecutedAt.ToString("f")</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                    <button type="button" class="btn btn-primary" @onclick="CopyToClipboard">Copy JSON</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<APICallHistoryDto> ApiCallHistories = new();
    private APICallHistoryDto? SelectedHistory;
    private bool IsLoading = true;
    private string FormattedResponseBody = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadHistoryData();
    }

    private async Task LoadHistoryData()
    {
        try
        {
            IsLoading = true;
            ApiCallHistories = await ApiClient.GetApiCallHistoryAsync();
        }
        catch (Exception ex)
        {
            await AlertService.Error($"Error loading history: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ShowResponseDetails(APICallHistoryDto history)
    {
        SelectedHistory = history;
        FormattedResponseBody = FormatJson(history.ResponseBody);
    }

    private void CloseModal()
    {
        SelectedHistory = null;
        FormattedResponseBody = "";
    }

    private string FormatJson(string json)
    {
        if (string.IsNullOrEmpty(json))
            return "No response body";

        try
        {
            using (JsonDocument doc = JsonDocument.Parse(json))
            {
                var options = new JsonSerializerOptions { WriteIndented = true };
                return JsonSerializer.Serialize(doc.RootElement, options);
            }
        }
        catch
        {
            return json;
        }
    }

    private async Task CopyToClipboard()
    {
        if (SelectedHistory == null)
            return;

        try
        {
            await Js.InvokeVoidAsync("navigator.clipboard.writeText", SelectedHistory.ResponseBody);
            await AlertService.Success("Copied to clipboard!");
        }
        catch
        {
            await AlertService.Error("Failed to copy to clipboard");
        }
    }
}
