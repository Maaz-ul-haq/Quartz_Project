@code {
    private IEnumerable<JobDto>? JobsList;
    private bool IsLoading = false;
    private bool ShowEmailJobForm = false;
    private bool ShowApiJobForm = false;
    private bool IsEditMode = false;

    private EmailJobRequest EmailJobForm = new();
    private HttpApiJobRequest ApiJobForm = new();

    private ModeType mode = ModeType.Manual;

    public enum ModeType { Manual, Builder }

    private int minute = 0;
    private int hour = 0;
    private string day = "*";
    private int interval = 0;



    protected override async Task OnInitializedAsync()
    {
        await LoadJobs();
    }

    private void ShowEmailPopup()
    {
        EmailJobForm = new EmailJobRequest();
        ShowEmailJobForm = true; 
        IsEditMode = false;        
    }

    private void ShowApiPopup()
    {
        ApiJobForm = new HttpApiJobRequest();
        ShowApiJobForm = true;
        IsEditMode = false;
    }

    private async Task LoadJobs()
    {
        IsLoading = true;
        try
        {
            var response = await ApiClient.GetAllJobsAsync();
            if (response.Success)
            {
                JobsList = response.Data ?? Enumerable.Empty<JobDto>();
            }
            else
            {
                Console.WriteLine($"Error: {response.Message}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task CreateEmailJob()
    {
        try
        {

            var response = await ApiClient.CreateEmailJobAsync(EmailJobForm);
            if (response.Success)
            {
                ShowEmailJobForm = false;
                EmailJobForm = new();
                await Alert.Success("Email job created successfully!");
                await LoadJobs();
            }
            else
            {
                await Alert.Error(response.Message);
            }
        }
        catch (Exception ex)
        {
            await Alert.Error(ex.Message, "Exception");
        }
    }

    private async Task CreateApiJob()
    {
        try
        {

            var response = await ApiClient.CreateHttpApiJobAsync(ApiJobForm);
            if (response.Success)
            {
                ShowApiJobForm = false;
                ApiJobForm = new();
                await LoadJobs();
                await Alert.Success(response.Message);
            }
            else
            {
                await Alert.Error(response.Message);
                Console.WriteLine($"Error: {response.Message}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception: {ex.Message}");
        }
    }

    private async Task DeleteJob(string jobId)
    {
        if (await ConfirmDelete())
        {
            try
            {
                var response = await ApiClient.DeleteJobAsync(jobId);
                if (response.Success)
                {
                    await LoadJobs();
                    await Alert.Success(response.Message);
                }
                else
                {
                    await Alert.Error(response.Message);
                    Console.WriteLine($"Error: {response.Message}");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Exception: {ex.Message}");
            }
        }
    }

    private async Task PauseJob(string jobId)
    {
        try
        {
            var response = await ApiClient.PauseJobAsync(jobId);
            if (response.Success)
            {
                await LoadJobs();
                await Alert.Success(response.Message);
            }
            else
            {
                await Alert.Error(response.Message);
                Console.WriteLine($"Error: {response.Message}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception: {ex.Message}");
        }
    }

    private async Task ResumeJob(string jobId)
    {
        try
        {
            var response = await ApiClient.ResumeJobAsync(jobId);
            if (response.Success)
            {
                await LoadJobs();
                await Alert.Success(response.Message);
            }
            else
            {
                await Alert.Error(response.Message);
                Console.WriteLine($"Error: {response.Message}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception: {ex.Message}");
        }
    }

    private async Task PopulatePopupForm(JobDto job)
    {
        if(job.JobType == JobType.SendEmail)
        {
            var emailJob = JsonSerializer.Deserialize<EmailJobRequest>(job.JobData);
            EmailJobForm = new EmailJobRequest
            {
                Id = job.Id,
                JobName = job.JobName,
                Description = job.Description,
                CronExpression = job.CronExpression,
                ToAddress = emailJob.ToAddress,
                Subject = emailJob.Subject,
                Body = emailJob.Body,
                IsHtml = emailJob.IsHtml
            };
            IsEditMode = true;
            ShowEmailJobForm = true;
        }
        else if(job.JobType == JobType.CallHttpApi)
        {
            var apiJob = JsonSerializer.Deserialize<HttpApiJobRequest>(job.JobData);
            ApiJobForm = new HttpApiJobRequest
            {
                Id = job.Id,
                JobName = job.JobName,
                Description = job.Description,
                CronExpression = job.CronExpression,
                Url = apiJob.Url,
                HttpMethod = apiJob.HttpMethod,
                Headers = apiJob.Headers,
                RequestBody = apiJob.RequestBody
            };
            IsEditMode = true;
            ShowApiJobForm = true;
        }
    }

    private async Task HandleEmailValidSubmit()
    {
        if (IsEditMode)
        {
           JobDto job = new JobDto
            {
                Id = EmailJobForm.Id ?? string.Empty,
                JobName = EmailJobForm.JobName,
                Description = EmailJobForm.Description,
                CronExpression = EmailJobForm.CronExpression,
                JobType = JobType.SendEmail,
                JobData = JsonSerializer.Serialize(EmailJobForm)
            };
            await EditJob(job);
        }
        else
        {
            await CreateEmailJob();
        }
    }
    private async Task HandleAPIValidSubmit()
    {
        if (IsEditMode)
        {
            JobDto job = new JobDto
            {
                Id = ApiJobForm.Id ?? string.Empty,
                JobName = ApiJobForm.JobName,
                Description = ApiJobForm.Description,
                CronExpression = ApiJobForm.CronExpression,
                JobType = JobType.CallHttpApi,
                JobData = JsonSerializer.Serialize(ApiJobForm)
            };
            await EditJob(job);
        }
        else
        {
            await CreateApiJob();
        }
    }

    private async Task EditJob(JobDto job)
    {
        try
        {

            var response = await ApiClient.UpdateJobAsync(job);
            if (response.Success)
            {
                IsEditMode = false;
                ShowApiJobForm = false;
                ShowEmailJobForm = false;
                await LoadJobs();
                await Alert.Success(response.Message);
            }
            else
            {
                await Alert.Error(response.Message);
                Console.WriteLine($"Error: {response.Message}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception: {ex.Message}");
        }
    }

    private Task<bool> ConfirmDelete()
    {
        return Task.FromResult(true);
    }

    private void GenerateCron(object form)
    {
        string expression = interval > 0
            ? $"0 */{interval} * ? * *"
            : $"0 {minute} {hour} ? * {day}";

        if (form is EmailJobRequest email)
        {
            email.CronExpression = expression;
        }
        else if (form is HttpApiJobRequest api)
        {
            api.CronExpression = expression;
        }
    }
}
