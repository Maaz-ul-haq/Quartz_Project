@page "/jobs"
@using QuartzUI.Services
@using System.Text.Json;
@inject ApiClient ApiClient
@inject NavigationManager Navigation
@inject SweetAlertService Alert

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <h1 class="mb-4">Quartz Jobs Manager</h1>

            <div class="row mb-4">
                <div class="col-md-6">
                    <button class="btn btn-primary btn-lg w-100" @onclick="() => ShowEmailPopup()">
                        ✉️ Create Email Job
                    </button>
                </div>
                <div class="col-md-6">
                    <button class="btn btn-success btn-lg w-100" @onclick="() => ShowApiPopup()">
                        🔗 Create HTTP API Job
                    </button>
                </div>
            </div>

            @if (IsLoading)
            {
                <div class="alert alert-info" role="alert">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    Loading jobs...
                </div>
            }
            else if (JobsList == null || !JobsList.Any())
            {
                <div class="alert alert-warning" role="alert">
                    No jobs created yet. Create your first job using the buttons above.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Job Name</th>
                                <th>Type</th>
                                <th>Cron Expression</th>
                                <th>Status</th>
                                <th>Last Executed</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var job in JobsList)
                            {
                                <tr>
                                    <td>
                                        <strong>@job.JobName</strong>
                                        <br />
                                        <small class="text-muted">@job.Description</small>
                                    </td>
                                    <td>
                                        @if (job.JobType == JobType.SendEmail)
                                        {
                                            <span class="badge bg-info">📧 Email</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">🔗 HTTP API</span>
                                        }
                                    </td>
                                    <td>
                                        <code>@job.CronExpression</code>
                                    </td>
                                    <td>
                                        @if (job.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Paused</span>
                                        }
                                    </td>
                                    <td>
                                        @if (job.LastExecutedAt.HasValue)
                                        {
                                            <small>@job.LastExecutedAt.Value.ToString("G")</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">Never</small>
                                        }
                                    </td>
                                    <td>
                                        @if (job.IsActive)
                                        {
                                            <button class="btn btn-sm btn-warning" @onclick="() => PauseJob(job.Id)">
                                                ⏸ Pause
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-success" @onclick="() => ResumeJob(job.Id)">
                                                ▶ Resume
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-info mx-1" @onclick="() => PopulatePopupForm(job)">
                                            ✏️ Edit
                                        </button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteJob(job.Id)">
                                            🗑️ Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>


@if (ShowEmailJobForm)
{
    <div class="modal show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(IsEditMode ? "Edit Email Job" : "Create Email Job")</h5>
                    <button type="button" class="btn-close" @onclick="() => ShowEmailJobForm = false"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="EmailJobForm" OnValidSubmit="HandleEmailValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Job Name</label>
                            <InputText class="form-control"
                                       @bind-Value="EmailJobForm.JobName" />
                            <ValidationMessage For="@(() => EmailJobForm.JobName)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputText class="form-control"
                                       @bind-Value="EmailJobForm.Description" />
                        </div>

                        <!-- CRON SECTION -->
                        <div class="mb-3">
                            <label class="form-label">Cron Expression</label>

                            <InputRadioGroup @bind-Value="mode">
                                <label class="me-3">
                                    <InputRadio Value="ModeType.Manual" /> Manual
                                </label>
                                <label>
                                    <InputRadio Value="ModeType.Builder" /> Builder
                                </label>
                            </InputRadioGroup>

                            @if (mode == ModeType.Manual)
                            {
                                <InputText class="form-control mt-2"
                                           @bind-Value="EmailJobForm.CronExpression" />
                                <ValidationMessage For="@(() => EmailJobForm.CronExpression)" />
                            }
                            else
                            {
                                <div class="row g-2 mt-2">

                                    <div class="col-md-3">
                                        <label>Minute</label>
                                        <InputNumber class="form-control"
                                                     @bind-Value="minute"
                                                     @bind-Value:after="() => GenerateCron(EmailJobForm)" />
                                    </div>

                                    <div class="col-md-3">
                                        <label>Hour</label>
                                        <InputNumber class="form-control"
                                                     @bind-Value="hour"
                                                     @bind-Value:after="() => GenerateCron(EmailJobForm)" />
                                    </div>

                                    <div class="col-md-3">
                                        <label>Day</label>
                                        <InputSelect class="form-control"
                                                     @bind-Value="day"
                                                     @bind-Value:after="() => GenerateCron(EmailJobForm)">
                                            <option value="*">Every Day</option>
                                            <option value="MON">Monday</option>
                                            <option value="TUE">Tuesday</option>
                                            <option value="WED">Wednesday</option>
                                            <option value="THU">Thursday</option>
                                            <option value="FRI">Friday</option>
                                            <option value="SAT">Saturday</option>
                                            <option value="SUN">Sunday</option>
                                        </InputSelect>
                                    </div>

                                    <div class="col-md-3">
                                        <label>Every (Minutes)</label>
                                        <InputNumber class="form-control"
                                                     @bind-Value="interval"
                                                     @bind-Value:after="() => GenerateCron(EmailJobForm)" />
                                    </div>

                                </div>

                                <div class="mt-2">
                                    <code>@EmailJobForm.CronExpression</code>
                                </div>
                            }

                            <small class="text-muted d-block mt-1">
                                Format: second minute hour day month day-of-week year
                            </small>
                        </div>

                        <hr />
                        <h6>Email Details</h6>

                        <div class="mb-3">
                            <label class="form-label">To Address</label>
                            <InputText class="form-control"
                                       @bind-Value="EmailJobForm.ToAddress" />
                            <ValidationMessage For="@(() => EmailJobForm.ToAddress)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <InputText class="form-control"
                                       @bind-Value="EmailJobForm.Subject" />
                            <ValidationMessage For="@(() => EmailJobForm.Subject)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Body</label>
                            <InputTextArea class="form-control"
                                           rows="5"
                                           @bind-Value="EmailJobForm.Body" />
                            <ValidationMessage For="@(() => EmailJobForm.Body)" />
                        </div>

                        <div class="form-check">
                            <InputCheckbox class="form-check-input"
                                           @bind-Value="EmailJobForm.IsHtml" />
                            <label class="form-check-label">HTML Email</label>
                        </div>

                        <div class="modal-footer mt-3">
                            <button type="button" class="btn btn-secondary"
                                    @onclick="() => ShowEmailJobForm = false">
                                Cancel
                            </button>

                            <button type="submit" class="btn btn-primary">
                                @(IsEditMode ? "Edit Job" : "Create Job")
                            </button>
                        </div>

                    </EditForm>
                </div>
                @* <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => ShowEmailJobForm = false">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="CreateEmailJob">Create Job</button>
                </div> *@
            </div>
        </div>
    </div>
}

