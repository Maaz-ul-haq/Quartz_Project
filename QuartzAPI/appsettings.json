{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },


  "Serilog": {
    "Using": [ "Serilog.Sinks.MSSqlServer", "Serilog.Sinks.Console" ],
    "MinimumLevel": "Error",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Connection string",
          "tableName": "Logs",
          "autoCreateSqlTable": true,
          "columnOptionsSection": {
            "id": { "columnName": "Id" },
            "message": { "columnName": "ExceptionMessage" },
            "timeStamp": { "columnName": "LoggedAt" },
            "removeStandardColumns": [ "MessageTemplate", "Level", "Exception", "Properties" ],
            "additionalColumns": [
              {
                "ColumnName": "InnerExceptionMessage",
                "PropertyName": "InnerExceptionMessage",
                "DataType": "nvarchar",
                "DataLength": -1,
                "AllowNull": true
              },
              {
                "ColumnName": "UserID",
                "PropertyName": "UserID",
                "DataType": "varchar",
                "DataLength": 100,
                "AllowNull": true
              }
            ]
          }
        }
      }
    ]
  },

  "Cors": "https://localhost:7084,http://localhost:5056",

  "Email": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": "587",
    "SenderEmail": "Your Email",
    "SenderPassword": "Password"
  },

  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Connection string"
  }

}

